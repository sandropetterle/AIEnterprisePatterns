# Normalize line endings to LF in the repository, LF in working tree.
# This overrides core.autocrlf and ensures consistent behaviour across
# Windows/macOS/Linux and all tools (git CLI, VS Code, Docker).

* text=auto eol=lf

# Explicitly binary — never touch line endings
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.db binary
*.db-shm binary
*.db-wal binary
