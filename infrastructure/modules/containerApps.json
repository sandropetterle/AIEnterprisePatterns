      "value": "[reference(resourceId('Microsoft.App/containerApps', 'ca-aipatterns-api-prod'), '2023-05-01', 'full').identity.principalId]"
    },
    "webPrincipalId": {
      "type": "string",
      "metadata": {
        "description": "Web Container App managed identity principal ID"
      },
      "value": "[reference(resourceId('Microsoft.App/containerApps', 'ca-aipatterns-web-prod'), '2023-05-01', 'full').identity.principalId]"
    },
    "cmsPrincipalId": {
      "type": "string",
      "metadata": {
        "description": "CMS Container App managed identity principal ID"
      },
      "value": "[reference(resourceId('Microsoft.App/containerApps', 'ca-aipatterns-cms-prod'), '2023-05-01', 'full').identity.principalId]"
    }
  }
