      "value": "[reference(resourceId('Microsoft.ContainerRegistry/registries', parameters('acrName')), '2023-01-01-preview').loginServer]"
    },
    "acrResourceId": {
      "type": "string",
      "metadata": {
        "description": "ACR resource ID (for managed identity pull role assignment)"
      },
