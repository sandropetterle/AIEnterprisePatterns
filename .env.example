# Backend API Configuration
# Copy this file to .env.local and update values as needed

# Backend API Base URL
# Development: http://localhost:5255/api
# Production: https://api.yourdomain.com/api
NEXT_PUBLIC_API_BASE_URL=http://localhost:5255/api

# API Request Timeout (milliseconds)
# Default: 30000 (30 seconds)
NEXT_PUBLIC_API_TIMEOUT=30000

# ---------------------------------------------------------------------------
# Authentication — Azure Entra External ID (or any OIDC provider)
# ---------------------------------------------------------------------------
# Generate a random secret: openssl rand -base64 32
AUTH_SECRET=

# OIDC Issuer URL (OIDC discovery document will be fetched from {issuer}/.well-known/openid-configuration)
# Entra External ID: https://{tenant-name}.ciamlogin.com/{tenant-name}.onmicrosoft.com/v2.0
# Auth0 example:     https://{your-domain}.auth0.com/
# Keycloak example:  https://{host}/realms/{realm-name}
AUTH_ENTRA_ISSUER=https://YOUR_TENANT.ciamlogin.com/YOUR_TENANT.onmicrosoft.com/v2.0

# App registration client ID (from Azure Portal > App registrations > AIPatterns-Web)
AUTH_ENTRA_CLIENT_ID=

# App registration client secret (from Azure Portal > App registrations > AIPatterns-Web > Certificates & secrets)
AUTH_ENTRA_CLIENT_SECRET=

# API scopes requested in the access token (must match the Backend API app registration)
AUTH_API_SCOPE_READ=api://aipatterns-api/patterns.read
AUTH_API_SCOPE_WRITE=api://aipatterns-api/patterns.write

# Required when deploying behind a proxy or to a non-localhost domain
AUTH_TRUST_HOST=true
