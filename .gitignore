# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.js

# testing
/coverage
/playwright-report/
/test-results/
/blob-report/

# next.js
/.next/
/out/
/.swc/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# local env files
.env*.local
.env

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# .NET backend
**/bin/
**/obj/
*.user
*.suo
.vs/

# SQLite database
*.db
*.db-shm
*.db-wal

# Docker
docker-compose.override.yml

# Azure deployment credentials (sensitive)
deployment/sql-credentials.txt
deployment/DEPLOYMENT_SUMMARY.txt
deployment/azure-resources-output.txt
deployment/azure-container-apps-output.txt
deployment/github-secrets-values.txt

# Playwright auth state (contains session cookies — never commit)
/e2e/.auth/

# Playwright MCP logs
/.playwright-mcp/
storybook-static/

# CMS local token (minted by mint-token.sh / restore.sh — never commit)
scripts/cms/.env.local-token

# CMS temporary backup bundles: *-roundtrip/ and *-verify/ patterns are in backups/cms/.gitignore

# Claude Code personal overrides (may accumulate one-off commands containing credentials - never commit)
.claude/settings.local.json
